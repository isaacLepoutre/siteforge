# Copie ce fichier en .env et remplace par ta vraie clé :
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxx

# Port du serveur proxy (optionnel, défaut : 3001)
PORT=3001

# URL du proxy pour le front-end en local (optionnel)
VITE_API_BASE_URL=http://localhost:3001

# Sur Netlify : ajoute ANTHROPIC_API_KEY dans
# Site settings → Environment variables (pas dans le code !)
